{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "student-toolsngsch.vercel.app"
        }
      ],
      "destination": "https://studenttoolsng.com/$1",
      "permanent": true
    }
  ],
  
  "routes": [
    {
      "src": "/sitemap.xml",
      "dest": "https://studenttoolsserver.onrender.com/api/sitemap"
    },
   
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]

}